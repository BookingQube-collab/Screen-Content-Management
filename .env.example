# Copy to `.env` in the repo root and fill in values. Never commit `.env`.

# Supabase project (ref: fiozifqhhawsvvtjamfo)
SUPABASE_URL=https://fiozifqhhawsvvtjamfo.supabase.co
SUPABASE_PROJECT_REF=fiozifqhhawsvvtjamfo

# Publishable/secret keys are NOT required for the current API (Drizzle + pg only).
# Add later if you adopt @supabase/supabase-js on the client.

# Postgres — required for API and `pnpm db:push`
#
# Direct (good for local drizzle-kit push / migrations):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.fiozifqhhawsvvtjamfo.supabase.co:5432/postgres?sslmode=require
#
# Pooler (preferred on Vercel/serverless; region from Supabase → Project Settings → Database):
# DATABASE_URL=postgresql://postgres.fiozifqhhawsvvtjamfo:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require
# Session pooler: port 5432 | Transaction pooler: port 6543
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.fiozifqhhawsvvtjamfo.supabase.co:5432/postgres?sslmode=require

# API server (artifacts/api-server)
JWT_SECRET=change-me-to-a-long-random-string
PORT=8080

# Vite apps (artifacts/urban-arena, artifacts/mockup-sandbox)
BASE_PATH=/
