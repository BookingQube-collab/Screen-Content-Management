# Copy to `.env` in the repo root and fill in values. Never commit `.env`.
#
# For Vercel: paste the SAME variable names and real values into each project's
# dashboard (Settings → Environment Variables). This file is documentation only;
# Vercel does not read `.env` from the repo.

# Supabase project (ref: fiozifqhhawsvvtjamfo)
SUPABASE_URL=https://fiozifqhhawsvvtjamfo.supabase.co
SUPABASE_PROJECT_REF=fiozifqhhawsvvtjamfo
SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY
SUPABASE_SECRET_KEY=sb_secret_YOUR_KEY
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_JWT

# Publishable/secret/anon keys are NOT required for the current API (Drizzle + pg only).
# Add when you adopt @supabase/supabase-js on the client or server.

# Postgres — required for API and `pnpm db:push`
#
# Session pooler (recommended for local dev + Vercel; region from Supabase → Database settings):
# uselibpqcompat avoids node-postgres SSL warnings; direct db.* host often times out on residential networks.
DATABASE_URL=postgresql://postgres.fiozifqhhawsvvtjamfo:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?uselibpqcompat=true&sslmode=require
#
# Direct (only if pooler is unavailable from your network):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.fiozifqhhawsvvtjamfo.supabase.co:5432/postgres?uselibpqcompat=true&sslmode=require
#
# Session pooler: port 5432 | Transaction pooler: port 6543 (append to URL if needed)

# API server (artifacts/api-server) — required on Vercel API project
JWT_SECRET=change-me-to-a-long-random-string-at-least-48-chars

# API server (artifacts/api-server) — local listen port; Vercel injects routing
PORT=8080

# Vite UI (artifacts/urban-arena) — local dev server; default 24725 if unset (not 3000)
# Override only if 24725 is taken: VITE_DEV_PORT=24726
# Vercel frontend *build* still sets PORT=3000 in the dashboard (any positive number; not exposed in static output)

# Required for Vite build (urban-arena, mockup-sandbox) and dev
BASE_PATH=/
