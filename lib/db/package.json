{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "default": "./src/schema/index.ts"
    }
  },
  "scripts": {
    "push": "drizzle-kit push --config ./drizzle.config.cjs",
    "push-force": "drizzle-kit push --force --config ./drizzle.config.cjs",
    "generate": "drizzle-kit generate --config ./drizzle.config.cjs",
    "migrate": "drizzle-kit migrate --config ./drizzle.config.cjs",
    "db:push": "pnpm run push",
    "db:generate": "pnpm run generate",
    "db:migrate": "pnpm run migrate"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.31.9"
  }
}
