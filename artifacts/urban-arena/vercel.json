{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm -w run build:libs && pnpm --filter @workspace/urban-arena run build",
  "outputDirectory": "dist/public",
  "env": {
    "PORT": "3000",
    "BASE_PATH": "/"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://screen-content-management-api-serve.vercel.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
